import java.util.Random;

public class TossGame {

    public static void main(String[] args) {

        String player1 = "Player 1";
        String player2 = "Player 2";

        char symbol1, symbol2;
        String currentPlayer;
        Random random = new Random();
        int toss = random.nextInt(2);
        if(toss == 0) {

            currentPlayer = player1;

            symbol1 = 'X';
            symbol2 = 'O';

            System.out.println(player1 + " won the toss and will start first.");

        } else {

            currentPlayer = player2;

            symbol1 = 'O';
            symbol2 = 'X';

            System.out.println(player2 + " won the toss and will start first.");
        }
        System.out.println(player1 + " Symbol: " + symbol1);
        System.out.println(player2 + " Symbol: " + symbol2);
        System.out.println("Current Player: " + currentPlayer);
    }
}
